#!/usr/bin/env bash
# agent-sandbox — run coding agents in a Docker Sandbox (microVM),
# with git-observable output and clone-mode isolation.
#
# The agent runs inside a disposable microVM. In clone mode it commits to a
# private clone; your repo is mounted read-only and you review its work with
# a normal git fetch / diff / merge.

set -euo pipefail

# ---- constants --------------------------------------------------------------

TOOL_NAME="agent-sandbox"
TOOL_VERSION="0.1.0"

# ---- output helpers ----------------------------------------------------------

_tput_color() {
  local code="$1"
  if [ -t 2 ] && command -v tput >/dev/null 2>&1; then
    tput setaf "$code" 2>/dev/null || true
  fi
}

_tput_reset() {
  if [ -t 2 ] && command -v tput >/dev/null 2>&1; then
    tput sgr0 2>/dev/null || true
  fi
}

log_info()  { printf '%s[info]%s  %s\n' "$(_tput_color 6)" "$(_tput_reset)" "$*" >&2; }
log_warn()  { printf '%s[warn]%s  %s\n' "$(_tput_color 3)" "$(_tput_reset)" "$*" >&2; }
log_error() { printf '%s[error]%s %s\n' "$(_tput_color 1)" "$(_tput_reset)" "$*" >&2; }
log_fatal() { log_error "$*"; exit 1; }

# ---- execution helpers -------------------------------------------------------

trace_cmd() {
  printf '+' >&2
  printf ' %q' "$@" >&2
  printf '\n' >&2
}

run_cmd() {
  if [ "${DRY_RUN:-0}" = 1 ]; then
    trace_cmd "$@"
  else
    "$@"
  fi
}

run_sbx() {
  run_cmd sbx "$@"
}

# ---- config ------------------------------------------------------------------

# Safe KEY=VALUE parser. Never sources config files.
load_config() {
  local file="$1"
  [ -f "$file" ] || return 0
  local line_num=0
  while IFS= read -r line || [ -n "$line" ]; do
    line_num=$((line_num + 1))
    # skip blanks and comments
    case "$line" in
      ""|\#*) continue ;;
    esac
    # must be KEY=VALUE
    if [[ "$line" != *=* ]]; then
      log_warn "sandbox.conf:$line_num: ignoring malformed line"
      continue
    fi
    local key="${line%%=*}"
    local val="${line#*=}"
    # strip optional quotes from value
    case "$val" in
      \"*\") val="${val#\"}"; val="${val%\"}" ;;
      \'*\') val="${val#\'}"; val="${val%\'}" ;;
    esac
    # validate key is a sane identifier
    if [[ ! "$key" =~ ^[A-Z_][A-Z0-9_]*$ ]]; then
      log_warn "sandbox.conf:$line_num: ignoring invalid key '$key'"
      continue
    fi
    # environment variables take precedence — only set if not already defined
    if [ -z "${!key+x}" ]; then
      export "$key=$val"
    fi
  done < "$file"
}

init_config() {
  # look for sandbox.conf next to the repo, then next to the script
  local script_dir
  script_dir="$(cd "$(dirname "$0")" && pwd)"
  local conf_locations=(
    "${REPO_DIR:-.}/sandbox.conf"
    "$script_dir/../conf/sandbox.conf"
  )
  for conf in "${conf_locations[@]}"; do
    if [ -f "$conf" ]; then
      load_config "$conf"
      break
    fi
  done
}

finalize_config() {
  : "${AGENT:=claude}"
  : "${REPO_DIR:=$PWD}"
  : "${DRY_RUN:=0}"
  : "${FORCE:=0}"
  : "${REVIEW_TOOL:=vscode}"

  # derive sandbox name from repo folder
  local repo_base
  repo_base="$(basename "$REPO_DIR")"
  local default_name="sbx-${repo_base//[^a-zA-Z0-9._-]/-}"
  : "${SANDBOX_NAME:=$default_name}"
  NAME="$SANDBOX_NAME"
}

# ---- validation helpers ------------------------------------------------------

require_tool() {
  command -v "$1" >/dev/null 2>&1 || log_fatal "Required command not found: $1"
}

require_repo() {
  git -C "$REPO_DIR" rev-parse --git-dir >/dev/null 2>&1 \
    || log_fatal "Not a git repository: $REPO_DIR (run 'git init' first)"
}

require_running() {
  sandbox_is_running || log_fatal "Sandbox '$NAME' is not running. Start it with: $TOOL_NAME up"
}

preflight() {
  [ "$DRY_RUN" = 1 ] && return 0
  require_tool sbx
  require_tool git
}

confirm() {
  local msg="$1"
  [ "$FORCE" = 1 ] && return 0
  if [ ! -t 0 ]; then
    log_fatal "$msg (use --force to skip confirmation in non-interactive mode)"
  fi
  printf '%s [y/N] ' "$msg" >&2
  local ans
  read -r ans
  case "$ans" in
    y|Y|yes|YES) return 0 ;;
    *) log_fatal "Aborted." ;;
  esac
}

# ---- sandbox lifecycle -------------------------------------------------------

sandbox_is_running() {
  [ "$DRY_RUN" = 1 ] && return 1
  sbx exec "$NAME" true >/dev/null 2>&1
}

sandbox_exists() {
  [ "$DRY_RUN" = 1 ] && return 1
  local sbx_list
  sbx_list="$(sbx ls 2>/dev/null)" || return 1
  printf '%s\n' "$sbx_list" | grep -qF "$NAME"
}

current_branch() {
  git -C "$REPO_DIR" symbolic-ref --short HEAD 2>/dev/null || echo main
}

sandbox_ref() {
  printf 'sandbox-%s/%s' "$NAME" "${1:-$(current_branch)}"
}

do_fetch() {
  run_cmd git -C "$REPO_DIR" fetch "sandbox-$NAME"
}

cleanup_partial_sandbox() {
  [ -n "${_CLEANUP_SBX_NAME:-}" ] || return 0
  log_warn "Cleaning up partial sandbox '$_CLEANUP_SBX_NAME'..."
  sbx rm "$_CLEANUP_SBX_NAME" 2>/dev/null || true
  _CLEANUP_SBX_NAME=""
}

agent_hint() {
  case "$AGENT" in
    claude)
      log_info "Auth: interactive /login in the sandbox, or: sbx secret set -g anthropic"
      ;;
    codex)
      log_info "Auth: run 'sbx secret set -g openai --oauth' or 'sbx secret set -g openai'"
      ;;
    opencode)
      log_info "Auth: store provider keys with sbx secret, e.g. openai, anthropic, google"
      ;;
    gemini)
      log_info "Auth: run 'sbx secret set -g google' to store your API key"
      ;;
  esac
}

# ---- commands ----------------------------------------------------------------

cmd_up() {
  preflight
  require_repo

  # Idempotent: if running, attach to existing sandbox
  if sandbox_is_running; then
    log_info "Sandbox '$NAME' is already running. Attaching..."
    if [ "$#" -gt 0 ]; then
      run_sbx run --name "$NAME" "$AGENT" "$@"
    else
      run_sbx run --name "$NAME" "$AGENT"
    fi
    return 0
  fi

  # If stopped/exists but not running, remove and recreate
  if sandbox_exists; then
    log_warn "Sandbox '$NAME' exists but is not running. Recreating..."
    run_sbx rm "$NAME"
  fi

  # Create fresh sandbox
  if [ "$DRY_RUN" = 1 ]; then
    log_info "Would start $AGENT in sandbox '$NAME' (clone mode)."
    agent_hint
    trace_cmd sbx create --clone --name "$NAME" "$AGENT" "$REPO_DIR"
    trace_cmd sbx run --name "$NAME" "$AGENT" "$@"
    return 0
  fi

  log_info "Starting $AGENT in sandbox '$NAME' (clone mode)."
  log_info "Review its commits on your host with: git fetch sandbox-$NAME"
  agent_hint

  # Trap-based cleanup: if create succeeds but run fails, remove the partial sandbox
  _CLEANUP_SBX_NAME="$NAME"
  trap cleanup_partial_sandbox EXIT

  sbx create --clone --name "$NAME" "$AGENT" "$REPO_DIR"

  if [ "$#" -gt 0 ]; then
    sbx run --name "$NAME" "$AGENT" "$@"
  else
    sbx run --name "$NAME" "$AGENT"
  fi

  # Success: disarm the trap
  _CLEANUP_SBX_NAME=""
  trap - EXIT
}

cmd_rm() {
  preflight

  if [ "$DRY_RUN" = 1 ]; then
    log_info "Would remove sandbox '$NAME'."
    trace_cmd sbx rm "$NAME"
    return 0
  fi

  if ! sandbox_exists && ! sandbox_is_running; then
    log_info "Sandbox '$NAME' does not exist. Nothing to remove."
    return 0
  fi

  confirm "Remove sandbox '$NAME'? Unfetched commits will be lost."

  # Offer to fetch first
  if [ "$FORCE" != 1 ] && [ -t 0 ]; then
    printf 'Fetch its commits first? [Y/n] ' >&2
    local ans
    read -r ans
    case "$ans" in
      n|N|no|NO) ;;
      *) git -C "$REPO_DIR" fetch "sandbox-$NAME" 2>/dev/null || true ;;
    esac
  fi

  sbx rm "$NAME"
  log_info "Removed sandbox '$NAME'."
}

cmd_stop() {
  preflight

  if [ "$DRY_RUN" = 1 ]; then
    log_info "Would stop sandbox '$NAME'."
    trace_cmd sbx stop "$NAME"
    return 0
  fi

  sbx stop "$NAME"
  log_info "Stopped '$NAME'. VM and commits are preserved."
}

cmd_merge() {
  preflight
  require_repo
  local base="${1:-$(current_branch)}"
  do_fetch
  log_info "Merging sandbox-$NAME/$base into $base"
  run_cmd git -C "$REPO_DIR" merge "$(sandbox_ref "$base")"
}

cmd_fetch() {
  preflight
  require_repo
  do_fetch
}

cmd_diff() {
  preflight
  require_repo
  local base="${1:-$(current_branch)}"
  do_fetch
  run_cmd git -C "$REPO_DIR" diff "$base..$(sandbox_ref "$base")"
}

cmd_shell() {
  preflight
  require_running
  run_sbx exec -it "$NAME" bash
}

cmd_status() {
  preflight
  log_info "Sandbox: $NAME"
  log_info "Agent:   $AGENT"
  log_info "Repo:    $REPO_DIR"

  if [ "$DRY_RUN" = 1 ]; then
    trace_cmd sbx exec "$NAME" true
    return 0
  fi

  if sandbox_is_running; then
    printf 'Status: %srunning%s\n' "$(_tput_color 2)" "$(_tput_reset)"
  elif sandbox_exists; then
    printf 'Status: %sstopped%s\n' "$(_tput_color 3)" "$(_tput_reset)"
  else
    printf 'Status: %snot found%s\n' "$(_tput_color 1)" "$(_tput_reset)"
  fi
}

cmd_doctor() {
  local doctor_ok doctor_warn doctor_fail reset
  doctor_ok="$(_tput_color 2)"    # green
  doctor_warn="$(_tput_color 3)"  # yellow
  doctor_fail="$(_tput_color 1)"  # red
  reset="$(_tput_reset)"

  local fails=0 warns=0

  _doc_ok()   { printf '%s[OK]%s   %s\n' "$doctor_ok"   "$reset" "$*"; }
  _doc_warn() { printf '%s[WARN]%s %s\n' "$doctor_warn"  "$reset" "$*"; warns=$((warns + 1)); }
  _doc_fail() { printf '%s[FAIL]%s %s\n' "$doctor_fail"  "$reset" "$*"; fails=$((fails + 1)); }

  printf '%s\n' "agent-sandbox doctor — checking system prerequisites"
  printf '%s\n' ""

  # 1. sbx
  if command -v sbx >/dev/null 2>&1; then
    local sbx_ver
    sbx_ver="$(sbx --version 2>/dev/null || echo "unknown")"
    _doc_ok "sbx installed ($sbx_ver)"
  else
    _doc_fail "sbx not found — install Docker Sandbox (https://docs.docker.com/sandbox/)"
  fi

  # 2. git
  if command -v git >/dev/null 2>&1; then
    local git_ver
    git_ver="$(git --version 2>/dev/null || echo "unknown")"
    _doc_ok "git installed ($git_ver)"
  else
    _doc_fail "git not found — install git"
  fi

  # 3. Platform virtualization
  local arch os_name
  os_name="$(uname -s 2>/dev/null || echo "Unknown")"
  arch="$(uname -m 2>/dev/null || echo "unknown")"

  case "$os_name" in
    Darwin)
      if [ "$arch" = "arm64" ]; then
        _doc_ok "macOS Apple Silicon (arm64) — native virtualization"
      else
        local hv_support
        hv_support="$(sysctl -n kern.hv_support 2>/dev/null || echo "0")"
        if [ "$hv_support" = "1" ]; then
          _doc_ok "macOS x86_64 — Hypervisor.framework supported"
        else
          _doc_fail "macOS x86_64 — Hypervisor.framework not available"
        fi
      fi
      ;;
    Linux)
      if [ -e /dev/kvm ]; then
        _doc_ok "Linux — /dev/kvm available"
      elif lsmod 2>/dev/null | grep -q kvm; then
        _doc_warn "Linux — KVM module loaded but /dev/kvm not accessible (check permissions)"
      else
        _doc_fail "Linux — KVM not available (enable hardware virtualization in BIOS)"
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*)
      _doc_warn "Windows/WSL detected — verify Hyper-V / WSL2 virtualization manually"
      ;;
    *)
      _doc_warn "Unknown platform '$os_name' — cannot verify virtualization support"
      ;;
  esac

  # 4. sbx daemon reachable and user logged in
  if command -v sbx >/dev/null 2>&1; then
    if sbx ls >/dev/null 2>&1; then
      _doc_ok "sbx daemon reachable and user logged in"
    else
      _doc_fail "sbx daemon not reachable or user not logged in (try 'sbx login')"
    fi
  else
    _doc_fail "sbx not installed — skipping daemon check"
  fi

  # Summary
  printf '\n'
  if [ "$fails" -gt 0 ]; then
    printf '%sSummary: %d fail(s), %d warning(s)%s\n' "$doctor_fail" "$fails" "$warns" "$reset"
    return 1
  elif [ "$warns" -gt 0 ]; then
    printf '%sSummary: 0 fails, %d warning(s) — review above%s\n' "$doctor_warn" "$warns" "$reset"
    return 0
  else
    printf '%sAll checks passed!%s\n' "$doctor_ok" "$reset"
    return 0
  fi
}

cmd_review() {
  preflight
  require_repo
  local base="${1:-$(current_branch)}"
  local tool="${REVIEW_TOOL:-vscode}"
  do_fetch

  local ref
  ref="$(sandbox_ref "$base")"

  if [ "$DRY_RUN" != 1 ]; then
    git -C "$REPO_DIR" rev-parse --verify "$ref" >/dev/null 2>&1 \
      || log_fatal "Sandbox branch not found: $ref"
  fi

  log_info "Opening visual review with difftool: $tool"
  run_cmd git -C "$REPO_DIR" difftool --dir-diff --no-prompt --tool="$tool" "$base" "$ref"
}

cmd_init() {
  local agents_file="$REPO_DIR/AGENTS.md"

  if [ "$DRY_RUN" = 1 ]; then
    log_info "Would create $agents_file"
    return 0
  fi

  [ -e "$agents_file" ] && log_fatal "AGENTS.md already exists in $REPO_DIR"

  cat >"$agents_file" <<'AGENTS_EOF'
# Agent Instructions

This repository may be worked on by sandboxed coding agents.

## Working Rules

- Inspect the repo before editing. Follow existing structure, style, and tooling.
- Keep changes small, reviewable, and focused on the requested task.
- Do not add dependencies, push to remotes, publish releases, or touch credentials unless explicitly asked.
- Prefer fixing root causes over broad rewrites.
- Commit finished work inside the sandbox so the host can fetch, diff, and merge it.

## Verification

- Run the most relevant tests, linters, formatters, or build checks for the change.
- If a check cannot be run, explain why in the final response.
- Report changed files and any known risks before stopping.
AGENTS_EOF

  log_info "Created $agents_file"
}

cmd_help() {
  cat <<EOF
$TOOL_NAME $TOOL_VERSION — run coding agents in a Docker Sandbox microVM

Usage: $TOOL_NAME [options] <command> [args]

Commands:
  up [-- agent-args]  Create/start sandbox (idempotent)
  shell               Open bash shell in the running sandbox
  fetch               git fetch the agent's commits
  diff  [base]        Fetch + diff base..sandbox branch
  review [base]       Fetch + visual difftool review
  merge [base]        Fetch + merge sandbox branch into base
  stop                Stop the sandbox (preserves commits)
  rm                  Remove the sandbox
  init                Create starter AGENTS.md in the target repo
  status              Show sandbox state
  doctor              Check system prerequisites
  help                Show this message

Options:
  --dry-run           Print commands without running them
  --force, --yes, -y  Skip confirmation prompts
  --agent <name>      Agent to use (default: claude)
  --repo <path>       Target repo (default: current directory)
  --name <name>       Override sandbox name
  --version, -v       Show version

Config: place a sandbox.conf in your repo root (see conf/sandbox.conf.example).
Active agent: $AGENT   Sandbox: $NAME
EOF
}

# ---- argument parsing & dispatch ---------------------------------------------

# Parse global options before the subcommand
while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --force|--yes|-y)
      FORCE=1
      shift
      ;;
    --agent)
      [ -n "${2:-}" ] || log_fatal "--agent requires a value"
      AGENT="$2"
      shift 2
      ;;
    --repo)
      [ -n "${2:-}" ] || log_fatal "--repo requires a value"
      REPO_DIR="$2"
      shift 2
      ;;
    --name)
      [ -n "${2:-}" ] || log_fatal "--name requires a value"
      SANDBOX_NAME="$2"
      shift 2
      ;;
    --version|-v)
      printf '%s %s\n' "$TOOL_NAME" "$TOOL_VERSION"
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      log_fatal "Unknown option: $1 (see '$TOOL_NAME help')"
      ;;
    *)
      break
      ;;
  esac
done

# Load config and finalize defaults (after CLI overrides are set)
init_config
finalize_config

# Dispatch subcommand
case "${1:-help}" in
  up)       shift; cmd_up "$@" ;;
  shell)    shift; cmd_shell ;;
  fetch)    shift; cmd_fetch ;;
  diff)     shift; cmd_diff "$@" ;;
  review)   shift; cmd_review "$@" ;;
  merge)    shift; cmd_merge "$@" ;;
  stop)     shift; cmd_stop ;;
  rm)       shift; cmd_rm ;;
  init)     shift; cmd_init ;;
  status)   shift; cmd_status ;;
  doctor)   shift; cmd_doctor ;;
  help|-h|--help) cmd_help ;;
  *)        log_error "Unknown command: $1"; echo; cmd_help; exit 1 ;;
esac
