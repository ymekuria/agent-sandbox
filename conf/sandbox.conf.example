# Copy this file to sandbox.conf (in your repo root) and edit.
# Every value is optional. sandbox.conf is git-ignored so local settings stay out of the repo.

# Name of the sandbox (default: sbx-<repo-folder-name>)
# SANDBOX_NAME=sbx-myproject

# Which agent to run (default: claude)
# Agents supported by Docker Sandboxes: claude, codex, opencode, gemini, copilot, cursor, droid, kiro, shell
# AGENT=claude

# Repo the agent operates on (default: current directory when running agent-sandbox)
# REPO_DIR=/absolute/path/to/repo

# Dry-run mode: print commands without executing them (default: 0)
# DRY_RUN=0

# Difftool for the review command (default: git's configured difftool via `git difftool`)
# If unset, falls back to whatever `git config diff.tool` returns.
# Built-in examples: opendiff (macOS FileMerge), vimdiff, meld, kdiff3
# REVIEW_TOOL=opendiff

# Global network policy: allow-all, balanced, deny-all (default: balanced)
# GLOBAL_NETWORK_POLICY=balanced

# Network allowlist for lockdown mode (comma-separated hosts)
# ALLOW=api.anthropic.com,*.anthropic.com,api.openai.com,*.openai.com,github.com,*.github.com,codeload.github.com,objects.githubusercontent.com,registry.npmjs.org,*.npmjs.org
